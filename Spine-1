!
frr version 10.6.1
frr defaults traditional
hostname spine-1
service integrated-vtysh-config
!
router bgp 65000
 bgp router-id 1.1.1.1
 no bgp ebgp-requires-policy
 no bgp default ipv4-unicast
 bgp bestpath as-path ignore
 !
 neighbor LEAF-OVERLAY peer-group
 neighbor LEAF-OVERLAY remote-as 65001
 neighbor LEAF-OVERLAY ebgp-multihop 5
 neighbor LEAF-OVERLAY update-source lo
 !
 neighbor 11.11.11.11 peer-group LEAF-OVERLAY
 neighbor 22.22.22.22 peer-group LEAF-OVERLAY
 !
 neighbor ens161 interface remote-as 65001
 no neighbor ens161 capability link-local
 neighbor ens256 interface remote-as 65001
 no neighbor ens256 capability link-local
 !
 address-family ipv4 unicast
  network 1.1.1.1/32
  neighbor ens161 activate
  neighbor ens256 activate
 exit-address-family
 !
 address-family l2vpn evpn
  neighbor LEAF-OVERLAY activate
  neighbor LEAF-OVERLAY route-reflector-client
 exit-address-family
exit
!
end
